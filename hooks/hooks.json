{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "(uv run ${CLAUDE_PLUGIN_ROOT}/scripts/notify.py done &) >/dev/null 2>&1"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "(uv run ${CLAUDE_PLUGIN_ROOT}/scripts/notify.py done &) >/dev/null 2>&1"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "(uv run ${CLAUDE_PLUGIN_ROOT}/scripts/notify.py plan &) >/dev/null 2>&1"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "(uv run ${CLAUDE_PLUGIN_ROOT}/scripts/notify.py off &) >/dev/null 2>&1"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "(uv run ${CLAUDE_PLUGIN_ROOT}/scripts/notify.py attention &) >/dev/null 2>&1"
          }
        ]
      }
    ]
  }
}
